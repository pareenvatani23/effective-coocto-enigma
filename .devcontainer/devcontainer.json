{
  "name": "Voice Cloning PoC",

  // Reuse the project's Dockerfile so the Codespace already has libsndfile,
  // ffmpeg, and all Python deps (torch, chatterbox-tts, gradio) baked in.
  "build": { "dockerfile": "../Dockerfile", "context": ".." },

  // Gradio listens on 7860. Codespaces forwards it over HTTPS.
  "forwardPorts": [7860],
  "portsAttributes": {
    "7860": {
      "label": "Gradio app (Voice Cloning PoC)",
      "onAutoForward": "notify"
    }
  },

  // The Dockerfile image runs as root; no extra user is created.
  "remoteUser": "root",

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  },

  "postAttachCommand": "echo '➡  Start the app:  python app.py   then open the PORTS tab, set port 7860 visibility to PUBLIC, and open its URL on your phone.'"
}
